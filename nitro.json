{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "omni"
  ],
  "ios": {
    "iosModuleName": "Omni"
  },
  "android": {
    "androidNamespace": [
      "omni"
    ],
    "androidCxxLibName": "Omni"
  },
  "autolinking": {
    "Omni": {
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridOmni"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}